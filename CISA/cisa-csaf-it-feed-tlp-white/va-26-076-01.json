      {
        "url": "https://raw.githubusercontent.com/cisagov/CSAF/develop/csaf_files/IT/white/2025/va-26-076-01.json",
        "summary": "Vulnerability Advisory VA-26-076-01 CSAF",
        "category": "self"
      }
    ]
  },
